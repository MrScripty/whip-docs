{
  "name": "whip-docs",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "npm@11.6.2",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "dev:desktop": "tauri dev",
    "build:desktop": "tauri build",
    "lint": "eslint src vite.config.ts svelte.config.js eslint.config.mjs --max-warnings 0",
    "lint:full": "eslint src src-tauri vite.config.ts svelte.config.js eslint.config.mjs --max-warnings 0",
    "typecheck": "tsc --project tsconfig.json --noEmit --pretty false",
    "test:frontend": "node --experimental-strip-types --test",
    "test": "npm run test:frontend",
    "check": "npm run lint && npm run typecheck && npm run test:frontend"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.9.0",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "lucide-svelte": "^0.562.0",
    "svelte": "^5.55.4",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tauri-apps/cli": "^2.9.0",
    "@types/node": "^22.14.0",
    "@types/three": "^0.184.0",
    "eslint": "^9.0.0",
    "eslint-plugin-svelte": "^3.0.0",
    "globals": "^16.0.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.2.0"
  }
}
